# CNPJ Data Pipeline Configuration

# Database (PostgreSQL via Docker on port 5435)
DATABASE_URL=postgres://postgres:postgres@localhost:5435/cnpj
# Aplica initial.sql (CREATE IF NOT EXISTS) no startup com OUTPUT_FORMAT=postgres. Desligar se o schema for gerenciado fora
# APPLY_DB_SCHEMA=true
# Caminho do DDL (padrão: vazio = /app/initial.sql na imagem Docker ou initial.sql no repo)
# INITIAL_SCHEMA_PATH=

# Processing
BATCH_SIZE=500000
TEMP_DIR=./temp

# Downloads (parallel)
DOWNLOAD_WORKERS=4

# Processing (parallel): files within the same dependency group
PROCESS_WORKERS=1

# Network
RETRY_ATTEMPTS=3
RETRY_DELAY=5
CONNECT_TIMEOUT=30
READ_TIMEOUT=300

# Loading strategy: "upsert" (default, keeps availability) or "replace" (faster, truncates tables)
LOADING_STRATEGY=upsert

# Receita Federal WebDAV (override se URL mudar)
# BASE_URL=https://arquivos.receitafederal.gov.br/public.php/webdav
# SHARE_TOKEN=YggdBLfdninEJX9

# Cleanup
KEEP_DOWNLOADED_FILES=false
